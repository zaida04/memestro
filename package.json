{
  "name": "@memestro/main",
  "version": "0.0.0",
  "private": true,
  "description": "Main overarching repo for memestro",
  "author": "Zaid \"Nico\"",
  "license": "MIT",
  "workspaces": [
    "services/*"
  ],
  "scripts": {
    "build": "yarn workspaces run build",
    "lint": "npx eslint services/ packages/",
    "lint:fix": "npx eslint services/ packages/ --fix",
    "prepare": "husky install",
    "prettier": "prettier --write **/*.{ts,js,json,yml,yaml}",
    "test": "yarn workspaces run test"
  },
  "devDependencies": {
    "@commitlint/cli": "^11.0.0",
    "@commitlint/config-angular": "^11.0.0",
    "@sapphire/eslint-config": "^4.0.3",
    "@sapphire/ts-config": "^3.1.4",
    "@typescript-eslint/eslint-plugin": "^4.28.5",
    "@typescript-eslint/parser": "^4.28.5",
    "dotenv": "^8.2.0",
    "eslint": "^7.6.0",
    "eslint-plugin-prettier": "^4.0.0",
    "husky": "^6.0.0",
    "lint-staged": "^10.4.2",
    "prettier": "^2.4.1",
    "rimraf": "^3.0.2",
    "ts-node": "^10.0.0",
    "typescript": "^4.0.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zaida04/memestro.git"
  },
  "lint-staged": {
    "*.ts": "eslint --fix"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-angular"
    ],
    "rules": {
      "scope-case": [
        2,
        "always",
        "pascal-case"
      ],
      "type-enum": [
        2,
        "always",
        [
          "chore",
          "build",
          "ci",
          "docs",
          "feat",
          "fix",
          "perf",
          "refactor",
          "revert",
          "style",
          "test"
        ]
      ]
    }
  },
  "prettier": {
    "endOfLine": "lf",
    "printWidth": 150,
    "quoteProps": "as-needed",
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "none",
    "useTabs": true
  }
}
